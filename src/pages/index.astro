---
import BaseLayout from '@/layouts/BaseLayout.astro'
import siteConfig from '@/site-config'
// import { Tweet } from '@astro-community/astro-embed-twitter'
---

<BaseLayout description={siteConfig.description}>
  <article class="prose">
    <h1 class="text-title">Dhruv Koli ⚡️</h1>
    <p>Competitive Programmer && Sophomore CSE at iiit dwd.</p>
    <p>
      This is my 🏡 residence on the web. If you like this, please consider
      following/ connecting with me on my Socials.
    </p>
    <p>🐐 messi fan.</p>
    <p>
      Thanks to <a href="https://kaivanwong.me/">Kevin Wong</a> and <a
        href="https://antfu.me/">Anthony Fu</a
      > for the inspiration.
    </p>

    <p>Check my posts here ➡️ <a href="/blog">All posts.</a></p>
    <p>and projects here ➡️ <a href="/projects">All projects.</a></p>

    <hr class="hr-line" />
    <p>Find me on</p>
    <p class="flex gap-x-4 gap-y-2 flex-wrap">
      {
        siteConfig.socialLinks.map((link) => (
          <a
            aria-label={link.text}
            href={link.href}
            target="_blank"
            class="prose-link"
          >
            <i class:list={[link.icon]} />
            {link.text}
          </a>
        ))
      }
    </p>
    <p>
      or mail me at
      <a
        prose-link
        aria-label={siteConfig.email}
        href={`mailto:${siteConfig.email}`}
      >
        {siteConfig.email}
      </a>.
    </p>
  </article>
</BaseLayout>
