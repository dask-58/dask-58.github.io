---
import { projectData } from './data'
import BaseLayout from '@/layouts/BaseLayout.astro'
import ListProjects from '@/components/ListProjects.vue'
---

<BaseLayout title="Projects" description="List of projects that I am proud of">
  <h1 class="mb-10 text-title">Projects</h1>
  <button class="back-button" @click="window.history.back()">Back</button>
  <div mb-16 sm:mb-24>
    {
      projectData.length > 0 && (
        <div>
          {projectData.map((i) => (
            <div mb-10>
              <h2 class="select-none relative h20 pointer-events-none">
                <span class="text-3.2em color-transparent font-bold text-stroke-1.5 text-stroke-hex-aaa op35 dark:op20 absolute top-0">
                  {i.title}
                </span>
              </h2>
              <ListProjects list={i.projects} />
            </div>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .back-button {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.5rem 1rem;
    font-size: 1rem;
    color: #ffffff;
    background-color: #007bff; /* Blue background for light mode */
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    transition: background-color 0.3s;
  }

  .back-button:hover {
    background-color: #0056b3; /* Darker blue on hover */
  }

  html.dark .back-button {
    background-color: #444; /* Dark background for dark mode */
  }

  html.dark .back-button:hover {
    background-color: #666; /* Lighter background on hover for dark mode */
  }

  .project-title {
    font-size: 3.2em;
    font-weight: bold;
    position: absolute;
    top: 0;
    color: #333; /* Default color for light mode */
    text-stroke: 1.5px #aaa;
    opacity: 0.35;
  }

  html.dark .project-title {
    color: #ddd; /* Lighter color for dark mode */
    text-stroke: 1.5px #444;
    opacity: 0.5; /* Increased opacity for better visibility */
  }
</style>
